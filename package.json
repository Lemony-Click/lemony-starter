{
	"name": "lemony-starter",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"dev": "turbo dev",
		"lint": "turbo lint",
		"format": "turbo format",
		"check": "biome check --write .",
		"typecheck": "turbo typecheck",
		"db:push": "bun run --filter @workspace/db prisma:push",
		"db:migrate": "bun run --filter @workspace/db prisma:migrate",
		"db:generate": "bun run --filter @workspace/db prisma:generate",
		"db:deploy": "bun run --filter @workspace/db prisma:deploy"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"turbo": "^2.8.17",
		"typescript": "5.9.3"
	},
	"packageManager": "bun@1.2.19",
	"engines": {
		"node": ">=20"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	]
}
