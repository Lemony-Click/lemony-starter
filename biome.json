{
	"$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
	"vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"**",
			"!!**/node_modules/",
			"!!**/dist/",
			"!!**/.turbo/",
			"!!**/coverage/",
			"!!**/generated/",
			"!!**/routeTree.gen.ts",
			"!!**/bun.lock",
			"!!**/pnpm-lock.yaml",
			"!!**/.pnpm-store/"
		]
	},
	"formatter": {
		"enabled": true
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"assist": {
		"enabled": true,
		"actions": { "source": { "organizeImports": "on" } }
	}
}
