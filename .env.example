# Copy to .env and fill in values for local development.
# The dev database (docker-compose.dev.yaml) uses:
#   postgres://postgres:postgres@localhost:5432/lemony
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lemony

# CORS origin for the API server (should match where the web app runs)
CORS_ORIGIN=http://localhost:5173

# Port the API server listens on
PORT=3000

# URL the web app uses to reach the API server
VITE_SERVER_URL=http://localhost:3000
